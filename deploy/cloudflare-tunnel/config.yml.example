tunnel: 00000000-0000-0000-0000-000000000000
credentials-file: ./cloudflared-credentials.json

ingress:
  - hostname: app.example.com
    path: /api/*
    service: http://127.0.0.1:18002
  - hostname: app.example.com
    path: /healthz
    service: http://127.0.0.1:18002
  - hostname: app.example.com
    service: http://127.0.0.1:18001
  - service: http_status:404
